{
  "name": "uppy-clone-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "audit": "npm audit --audit-level=high",
    "test": "vitest run",
    "test:frontend": "vitest run --coverage",
    "test:coverage": "npm run test:frontend",
    "test:frontend:gate": "npm run test:frontend"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "fast-check": "^4.8.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
