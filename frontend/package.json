{
  "name": "uppy-clone-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,json}\"",
    "audit": "npm audit --audit-level=high",
    "test": "vitest run",
    "test:frontend": "vitest run --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.1",
    "prettier": "^3.9.5",
    "ts-prune": "^0.10.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "i18next": "^26.3.6"
  }
}
