# Dependencies
node_modules/

# Build output
dist/
bin/
.wrangler/

# Environment & secrets
.dev.vars
.env
.env.*
!.env.example

# IDE working data (但保留 specs 需求文档)
.trae/*
!.trae/specs/
.superpowers/

# Coverage & test output
coverage/
test-results/
playwright-report/
backend/coverage.out
backend/coverage.html
backend/coverage.txt
backend/coverage
backend/coverage_*
backend/cov_*

# Build artifacts
backend/server
backend/server.exe
backend/*.exe
backend/*.test
backend/bin/
backend/store/

# Coverage & test binaries (ad-hoc profiles dropped by `go test -coverprofile`)
backend/*.out
backend/*cov*
backend/*cover*
# Ad-hoc coverprofile files without .out suffix (must not collide with package names)
backend/migrate
backend/seed
backend/backfill
backend/server
backend/unit
backend/handler
backend/unit_focus
backend/$out

# Security/audit scan reports
*-report.txt
leaks.json
staged.txt
staged_list.txt

# Lint output
lint-*.txt
lint-output.txt
lint-all.txt
lint-detailed.txt
lint-full.txt
lint-json.txt

# Profiling output
*.prof
*.pprof

# Legacy & temp files
*.legacy
*.tmp
*.bak

# Python cache
__pycache__/
*.py[cod]

# Logs
*.log
