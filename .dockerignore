# Enterprise rationale: .dockerignore prevents sensitive files (.git, .env)
# and unnecessary files (docs, tests) from entering the Docker build context.
# This reduces build time, context size, and attack surface.

# Version control
.git
.gitignore

# Dependencies (installed via npm ci / go mod download in Dockerfile)
node_modules
frontend/node_modules

# Documentation
*.md
docs/
!backend/migrations/README.md

# Test files
**/*_test.go
playwright-report/
test-results/
coverage/
playwright.config.ts

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment & secrets
.env
.env.*
.dev.vars
.dev.vars.*
.trae/

# Build artifacts (rebuilt in Dockerfile)
frontend/dist/

# Scripts
scripts/

# Infrastructure
infra/
.terraform/

# CI
.github/

# Other
*.log
tmp/
.superpowers/
