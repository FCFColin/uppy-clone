{
  "name": "uppy-clone",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "powershell -File scripts/dev/start-dev.ps1",
    "dev:frontend": "powershell -File scripts/dev/run-frontend.ps1",
    "dev:backend": "powershell -File scripts/dev/run-backend.ps1",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && go build ./cmd/server",
    "test:backend": "make test",
    "test:e2e": "playwright test",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "concurrently": "^10.0.3",
    "typescript": "^5.6.0"
  }
}
