# ===========================================
# Environment Variables Configuration
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file.

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable
# Home region for this instance (multi-region, ADR-014/016). Empty = single-region.
# DEPLOY_REGION=
# This region's client-facing WebSocket base, returned to clients for nearest-region
# reconnect when a room lives in another region (ADR-016). e.g. wss://us.balloon.example
# REGION_WS_ENDPOINT=
# Graceful drain delay on SIGTERM before closing rooms (ADR-005). Default 5s.
# DRAIN_DELAY=5s

# --- Redis ---
# Stateful Redis: room registry, JWT revocation, magic links, refresh tokens,
# email queue, game results, outbox, Pub/Sub. Requires persistence (AOF/RDB).
# Local dev: host:port (no password). Docker Compose: redis://:password@redis:6379
REDIS_URL=localhost:6379
# Ephemeral Redis: rate limiting & idempotency cache (ADR-029).
# Tolerant of data loss, fail-open safe. When unset, falls back to REDIS_URL.
# REDIS_EPHEMERAL_URL=localhost:6380
# Regional Redis: overrides REDIS_URL for stateful data in multi-region deploy (ADR-029 Phase 3).
# When set, stateful Redis uses this URL; REDIS_URL becomes fallback for ephemeral.
# REDIS_REGIONAL_URL=
# Dedicated Pub/Sub Redis (defaults to stateful Redis when unset)
# REDIS_PUBSUB_URL=
# Connection pool (logged at startup)
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5

# --- PostgreSQL pool (logged at startup; alias PG_MAX_CONNS = PG_POOL_MAX_CONNS) ---
PG_POOL_MAX_CONNS=25
PG_POOL_MIN_CONNS=5
PG_POOL_MAX_CONN_LIFETIME=30m
PG_POOL_MAX_CONN_IDLE_TIME=5m

# --- Security (REQUIRED) ---
# JWT signing uses ECDSA P-256 (ES256). Provide PEM-encoded keys.
# Generate a key pair with:
#   openssl ecparam -name prime256v1 -genkey -noout -out private.pem
#   openssl ec -in private.pem -pubout -out public.pem
# JWT_PRIVATE_KEY: EC PRIVATE KEY (SEC1) PEM, e.g.:
#   -----BEGIN EC PRIVATE KEY-----
#   <base64 body lines>
#   -----END EC PRIVATE KEY-----
JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY: PUBLIC KEY (SubjectPublicKeyInfo) PEM — required when ENV=production:
#   -----BEGIN PUBLIC KEY-----
#   <base64 body lines>
#   -----END PUBLIC KEY-----
JWT_PUBLIC_KEY=
# Encryption key for data at rest (32 bytes hex). Generate: openssl rand -hex 32
ENCRYPTION_KEY=RUN_openssl_rand_hex_32_TO_GENERATE
ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
# Required when ENABLE_HSTS is not false (production). GKE deploy injects via
# infra/k8s overlays (__TRUSTED_PROXY_CIDRS__ → GitHub secret TRUSTED_PROXY_CIDRS).
TRUSTED_PROXY_CIDRS=

# --- Optional: Audit log HMAC secret (falls back to JWT_PRIVATE_KEY) ---
AUDIT_SECRET=

# --- Server ports (change here only) ---
PORT=57266
FRONTEND_PORT=52175
BACKEND_URL=http://localhost:57266
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:52175
# Path to SQL migrations when running server from repo root (Docker uses ./migrations)
MIGRATIONS_DIR=backend/migrations
FRONTEND_DIR=frontend/dist

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
METRICS_USER=dev-metrics
METRICS_PASSWORD=change-me-in-production

# --- Server ---
# ENV: set to "production" to enable production-only validation (JWT_PUBLIC_KEY &
# TRUSTED_PROXY_CIDRS required, weak JWT secrets rejected). Omit/empty for dev.
# ENV=
# Max WebSocket connections per IP (default 1000).
# MAX_WS_CONNECTIONS=1000
# Max players per game room (default 50).
# MAX_PLAYERS_PER_ROOM=50
LOG_LEVEL=info
# Local dev: disable HSTS to skip METRICS_USER/PASS requirement
ENABLE_HSTS=false
