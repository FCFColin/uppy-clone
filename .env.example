# ===========================================
# Environment Variables Configuration
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file.

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable
# SQL dialect: "postgres" (default, single-region) or "cockroach" (multi-region, ADR-015).
# When "cockroach", CRDB-only locality (REGIONAL BY ROW / GLOBAL) is applied on migrate.
# DB_DIALECT=postgres
# Home region for this instance (multi-region, ADR-014/016). Empty = single-region.
# DEPLOY_REGION=
# This region's client-facing WebSocket base, returned to clients for nearest-region
# reconnect when a room lives in another region (ADR-016). e.g. wss://us.balloon.example
# REGION_WS_ENDPOINT=
# Graceful drain delay on SIGTERM before closing rooms (ADR-005). Default 5s.
# DRAIN_DELAY=5s

# --- Redis ---
REDIS_URL=localhost:6379
# Connection pool (logged at startup)
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5

# --- PostgreSQL pool (logged at startup; alias PG_MAX_CONNS = PG_POOL_MAX_CONNS) ---
PG_POOL_MAX_CONNS=25
PG_POOL_MIN_CONNS=5
PG_POOL_MAX_CONN_LIFETIME=30m
PG_POOL_MAX_CONN_IDLE_TIME=5m

# --- Room performance feature flags (ADR-027) ---
ENABLE_ROOM_OUTBOUND_QUEUE=true
ENABLE_ASYNC_ROOM_PERSIST=true

# --- Security (REQUIRED — generate with openssl rand -hex 32) ---
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING
ENCRYPTION_KEY=RUN_openssl_rand_hex_32_TO_GENERATE
ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
ADMIN_JWT_SECRET=RUN_openssl_rand_hex_32_TO_GENERATE

# --- Optional: Audit log HMAC secret (falls back to JWT_SECRET) ---
AUDIT_SECRET=

# --- Reverse proxy trust (comma-separated CIDRs; empty = trust no X-Forwarded-*) ---
TRUSTED_PROXY_CIDRS=

# --- CORS ---
FRONTEND_PORT=5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
METRICS_USER=dev-metrics
METRICS_PASSWORD=change-me-in-production

# --- Debug (pprof) ---
# ENABLE_PPROF=true
# DEBUG_PORT=6060

# --- Server ---
PORT=8080
LOG_LEVEL=info
# Local dev: disable HSTS to skip METRICS_USER/PASS requirement
ENABLE_HSTS=false
