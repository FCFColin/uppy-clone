{
  "name": "uppy-clone-dev",
  "image": "mcr.microsoft.com/devcontainers/go:1.26",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers-contrib/features/golangci-lint:1": {}
  },
  "postCreateCommand": "go install github.com/air-verse/air@latest && go install -tags 'postgres' github.com/golang-migrate/migrate/v4/cmd/migrate@latest && go mod download && docker compose up -d postgres redis",
  "forwardPorts": [8080, 5432, 6379, 6060],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "editor.formatOnSave": true
      }
    }
  },
  "remoteEnv": {
    "DATABASE_URL": "postgres://uppy:uppy@localhost:5432/uppy?sslmode=disable",
    "REDIS_URL": "localhost:6379"
  }
}
