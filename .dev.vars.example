# Uppy Clone 环境变量配置
# 复制此文件为 .dev.vars 并填入实际值

# JWT 密钥（生产环境必须设置，否则每次冷启动生成随机密钥导致会话失效）
JWT_SECRET=your-secret-key-here

# 管理员密码（生产环境必须设置，空值表示管理后台不可用）
ADMIN_PASSWORD=your-admin-password

# AES-256-GCM 加密密钥（64 个十六进制字符 = 32 字节，生产环境必须设置独立密钥）
# 可用命令生成：openssl rand -hex 32
ENCRYPTION_KEY=RUN_openssl_rand_hex_32_TO_GENERATE

# Resend API Key（邮件登录功能，可选）
RESEND_API_KEY=re_xxxxxxxxxxxx
